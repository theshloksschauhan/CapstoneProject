# Backend environment variables for local development and deployment.

# MongoDB connection string. In Docker Compose, this points at the internal mongo service.
MONGO_URL=mongodb://mongo:27017

# Database name used by the API.
DB_NAME=careeros

# Required. Change this before deploying; used to sign JWT access and refresh tokens.
JWT_SECRET=change-me-before-deploy

# Required. Provide your OpenAI API key for all AI-powered routes.
OPENAI_API_KEY=sk-your-openai-key

# Optional. OpenAI model to use for generation.
OPENAI_MODEL=gpt-4o

# Allowed frontend origin for CORS. Use a comma-separated list for split-domain deploys.
FRONTEND_URL=http://localhost:3000

# Set to true in production HTTPS deployments so auth cookies are marked Secure.
COOKIE_SECURE=false

# Initial admin email address.
ADMIN_EMAIL=admin@careeros.ai

# Required. Change this before deploying; used to seed the initial admin account.
ADMIN_PASSWORD=change-me-before-deploy

# Maximum AI generations allowed per user per day.
DAILY_AI_RUN_LIMIT=20